# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Environment
.env
.env.local

# Generated specs (rebuilt via `uv run pydoc-markdown`)
specs/generated/

# Instance runtime artifacts
sidestage/logs/

# Per-campaign FalkorDBLite runtime files (graph DB + AOF dir + redislite
# settings). Source-of-truth state is the markdown; the DB is regenerated
# on first launch via Campaign.import_from_disk. Pattern covers both
# the real sidestage/campaigns/ and the test fixture campaigns under
# tests/sidestage/campaigns/ (touched by browser e2e via App.run).
**/campaigns/*/falkor.db
**/campaigns/*/falkor.db.settings
**/campaigns/*/appendonlydir/

# Node — covers frontend/ and tests/playwright/ trees
node_modules/

# Frontend build output (also written to FastAPI static mount)
frontend/dist/
frontend/.vite/
src/sidestage/static/

# Auto-generated TypeScript wire types — regenerated by `just _gen-types`
# from the Pydantic models. Every FE consumer (tsc, vitest, vite) declares
# `_gen-types` as a dep so the file is always fresh.
frontend/src/types.ts

# Playwright artifacts
tests/playwright/test-results/
tests/playwright/playwright-report/

# IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.DS_Store
*.swp

# Claude
.claude/plans/
