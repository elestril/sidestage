#!/usr/bin/env bash
#
# Pre-commit gate — runs `just test-all` (lint + Python + frontend +
# browser) before any commit. Skippable with `git commit --no-verify`
# when you genuinely need to (e.g. WIP commit during pair work).
#
# Install via `just install-hooks` after cloning.

set -euo pipefail

exec just test-all
